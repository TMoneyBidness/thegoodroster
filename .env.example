# =============================================================================
# TheGoodRoster — Environment Variables
# Copy this file to .env and fill in actual values
# =============================================================================

# --- Site Identity ---
# Company/entity name operating the site
PUBLIC_COMPANY_NAME="TheGoodRoster"
# Production domain
PUBLIC_SITE_URL="https://thegoodroster.com"
# Site display name
PUBLIC_SITE_NAME="TheGoodRoster"

# --- Editorial ---
# Named author/reviewer shown on content pages
PUBLIC_EDITORIAL_AUTHOR_NAME="[EDITORIAL_AUTHOR_NAME]"
PUBLIC_EDITORIAL_AUTHOR_CREDENTIAL="[EDITORIAL_AUTHOR_CREDENTIAL]"

# --- Contact ---
# BIA general contact (not a loan officer line)
PUBLIC_CONTACT_EMAIL="[CONTACT_EMAIL]"
PUBLIC_CONTACT_PHONE="[CONTACT_PHONE]"

# --- Analytics ---
PUBLIC_GA4_MEASUREMENT_ID="[GA4_MEASUREMENT_ID]"

# --- Cloudflare Turnstile (anti-spam) ---
PUBLIC_TURNSTILE_SITE_KEY="[TURNSTILE_SITE_KEY]"
# Secret key — used server-side in Worker only, never exposed to client
TURNSTILE_SECRET_KEY="[TURNSTILE_SECRET_KEY]"

# --- Lead Routing (Worker secrets — set via wrangler secret) ---
# Webhook endpoint where leads are POSTed (N8N, Apps Script, Zapier, etc.)
WEBHOOK_AUTOMATION_URL="[WEBHOOK_AUTOMATION_URL]"
# Shared secret for HMAC verification on webhook receiver
WEBHOOK_AUTOMATION_SECRET="[WEBHOOK_AUTOMATION_SECRET]"

# --- Cloudflare Resources ---
CLOUDFLARE_ACCOUNT_ID="[CLOUDFLARE_ACCOUNT_ID]"
D1_DATABASE_ID="[D1_DATABASE_ID]"
