---
interface Props {
  name: string;
  agency: string;
  maxAssistance: string;
  geography: string;
  incomeLimit: string;
  requiresFTHB: boolean;
  detailUrl?: string;
  highlight?: boolean;
}

const { name, agency, maxAssistance, geography, incomeLimit, requiresFTHB, detailUrl, highlight = false } = Astro.props;
---
<div class:list={[
  'rounded-xl border border-neutral-200 p-6 bg-white shadow-sm',
  highlight ? 'border-accent-300 bg-accent-50/30' : '',
]}>
  <div class="flex items-start justify-between gap-4 mb-3">
    <div>
      <h3 class="font-bold text-neutral-900">{name}</h3>
      <p class="text-body-sm text-neutral-500">{agency}</p>
    </div>
    {highlight && (
      <span class="flex-shrink-0 px-2 py-1 bg-primary-100 text-primary-700 text-xs font-semibold rounded-full">
        Popular
      </span>
    )}
  </div>

  <div class="space-y-2 text-body-sm">
    <div class="flex items-start gap-2">
      <span class="text-primary-600 font-bold text-body">$</span>
      <div>
        <p class="font-semibold text-neutral-800">Up to {maxAssistance}</p>
        <p class="text-neutral-500">Maximum assistance</p>
      </div>
    </div>

    <div class="flex items-center gap-2 text-neutral-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      {geography}
    </div>

    <div class="flex items-center gap-2 text-neutral-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      Income limit: {incomeLimit}
    </div>

    {requiresFTHB && (
      <div class="flex items-center gap-2 text-neutral-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        First-time homebuyer required
      </div>
    )}
  </div>

  {detailUrl && (
    <a href={detailUrl} class="mt-4 inline-flex items-center text-body-sm font-medium text-accent-600 hover:text-accent-700 no-underline" aria-label={`Learn more about ${name}`}>
      Learn more
      <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  )}
</div>
