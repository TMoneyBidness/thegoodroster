---
import { siteConfig } from '../../config/site';
import DisclaimerBar from './DisclaimerBar.astro';
import Nav from './Nav.astro';
import MobileNav from './MobileNav.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
---
<header class="sticky top-0 z-40 bg-white border-b border-neutral-200">
  <DisclaimerBar />

  <div class="container-content">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Site Name -->
      <a href="/" class="flex items-center gap-2 text-primary-800 font-bold text-h3 no-underline hover:text-primary-700" aria-label={`${siteConfig.siteName} — Home`}>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span class="hidden sm:inline">{siteConfig.siteName}</span>
      </a>

      <!-- Desktop Nav -->
      <Nav currentPath={currentPath} />

      <!-- Right side: phone + hamburger -->
      <div class="flex items-center gap-3">
        {siteConfig.contactPhone && siteConfig.contactPhone !== '[CONTACT_PHONE]' && (
          <a
            href={`tel:${siteConfig.contactPhone}`}
            class="hidden md:flex items-center gap-1.5 text-body-sm font-medium text-primary-700 hover:text-primary-800"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {siteConfig.contactPhone}
          </a>
        )}

        <!-- Mobile hamburger -->
        <button
          id="open-mobile-nav"
          class="lg:hidden p-3 min-h-[44px] min-w-[44px] flex items-center justify-center text-neutral-600 hover:text-primary-800"
          aria-label="Open menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<MobileNav currentPath={currentPath} />
