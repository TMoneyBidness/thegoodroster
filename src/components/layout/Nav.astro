---
import { siteConfig } from '../../config/site';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
---
<nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
  {siteConfig.nav.map((item) => (
    <a
      href={item.href}
      class:list={[
        'px-3 py-2 rounded-md text-body-sm font-medium border-b-2 transition-all duration-150',
        'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 focus-visible:ring-offset-2',
        currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
          ? 'text-accent-700 border-accent-500 bg-accent-50'
          : 'text-primary-700 border-transparent hover:text-accent-600 hover:border-accent-300',
      ]}
      aria-current={currentPath === item.href ? 'page' : undefined}
    >
      {item.label}
    </a>
  ))}
</nav>
