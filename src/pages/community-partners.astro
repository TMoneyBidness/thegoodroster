---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config/site';
import partners from '../data/partners.json';
import PartnerConnectForm from '../components/partners/PartnerConnectForm.tsx';

const activePartners = partners.filter((p) => p.isActive);
---
<PageLayout
  title={`Community Partners | ${siteConfig.siteName}`}
  description={`Connect with licensed mortgage professionals serving San Diego. You choose who to contact — ${siteConfig.siteName} does not assign or route on your behalf.`}
  breadcrumbs={[{ label: 'Community Partners', href: '/community-partners/' }]}
  wide={true}
>
  <!-- Hero -->
  <div class="py-12 text-center max-w-3xl mx-auto">
    <h1 class="text-h1 font-bold text-primary-800 mb-4">
      One Pro. Picked by You. Your Inquiry Goes Only to Them.
    </h1>
    <p class="text-body-lg text-neutral-600 mb-3">
      A small roster of licensed San Diego mortgage professionals with clear specialties. You choose who to contact. No one else gets your information.
    </p>
    <p class="text-body-sm text-neutral-500">
      Not sure who fits? <a href="/tools/dpa-finder/" class="text-accent-600 hover:text-accent-700 font-medium">Find your DPA match first</a> — it takes 60 seconds.
    </p>
  </div>

  <!-- Anti-spam guarantee -->
  <div class="max-w-3xl mx-auto mb-8 px-4">
    <div class="bg-green-50 border border-green-200 rounded-xl p-6 flex items-start gap-4">
      <div class="flex-shrink-0 w-10 h-10 rounded-full bg-green-100 flex items-center justify-center text-green-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
      </div>
      <div>
        <p class="font-bold text-primary-800 mb-1">$100 Anti-Spam Guarantee</p>
        <p class="text-body-sm text-neutral-600">
          Your contact info goes <strong>only</strong> to the one professional you choose. If anyone you didn't select contacts you through TheGoodRoster, we'll PayPal you $100 within 48 hours. That's how seriously we take your privacy.
        </p>
      </div>
    </div>
  </div>

  <!-- Community Partners listing -->
  <div class="max-w-4xl mx-auto mb-16">
    {activePartners.length === 0 && (
      <div class="bg-primary-50 border border-primary-200 rounded-xl p-8 text-center mb-12">
        <p class="text-body text-neutral-700 mb-3">
          Our Community Partner roster is being finalized. We're vetting licensed professionals who specialize in San Diego first-time buyer programs.
        </p>
        <p class="text-body-sm text-neutral-500 mb-4">In the meantime, explore our free tools and DPA guides to understand your options.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/tools/dpa-finder/" class="btn-primary no-underline">Find My DPA Match</a>
          <a href="/down-payment-assistance-san-diego/" class="btn-secondary no-underline">Browse DPA Programs</a>
        </div>
      </div>
    )}

    {activePartners.length > 0 && (
      <p class="text-body text-neutral-600 mb-2">A small roster of licensed local experts with clear specialties.</p>
    )}
    {activePartners.length > 0 && (
      <p class="text-body-sm text-neutral-400 mb-8">Roster order is randomized. Professionals are not ranked by payment.</p>
    )}

    <div class="space-y-8">
      {activePartners.map((partner) => (
        <div class="bg-white border border-neutral-200 rounded-xl shadow-sm overflow-hidden" id={`partner-${partner.id}`}>
          <!-- Partner info header -->
          <div class="p-6 border-b border-neutral-100">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
              <div>
                <h3 class="text-h3 font-bold text-primary-800 mb-1">
                  {partner.name}
                </h3>
                <p class="text-body-sm text-neutral-600">{partner.legalEntityName}</p>
                <p class="text-body-sm text-neutral-500">
                  NMLS#
                  <a
                    href={`https://www.nmlsconsumeraccess.org/EntityDetails.aspx/INDIVIDUAL/${partner.nmls}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline"
                  >{partner.nmls}</a>
                  {partner.entityNmls && (
                    <> | Entity NMLS#
                      <a
                        href={`https://www.nmlsconsumeraccess.org/EntityDetails.aspx/COMPANY/${partner.entityNmls}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="underline"
                      >{partner.entityNmls}</a>
                    </>
                  )}
                </p>
                <p class="text-body-sm text-neutral-500 mt-1">
                  {partner.yearsExperience}+ years experience
                  {partner.languages.length > 1 && <> &middot; Speaks {partner.languages.join(', ')}</>}
                  {partner.address && <> &middot; {partner.address}</>}
                </p>
                {partner.stateLicenses && (
                  <p class="text-body-sm text-neutral-400 mt-0.5">{partner.stateLicenses}</p>
                )}
              </div>

              <!-- Direct call (always available, no consent needed for outbound) -->
              <div class="flex-shrink-0">
                <a href={`tel:${partner.phone}`} class="btn-secondary text-body-sm py-2 px-4">
                  Call {partner.phone}
                </a>
              </div>
            </div>

            <!-- Specializations -->
            <div class="flex flex-wrap gap-2 mt-3">
              {partner.specializations.map((spec) => (
                <span class="inline-block bg-accent-50 text-accent-700 text-xs font-medium px-2.5 py-1 rounded-full">
                  {spec}
                </span>
              ))}
            </div>

            <p class="text-body text-neutral-600 mt-3">{partner.bio}</p>
          </div>

          <!-- Per-professional consent + contact form -->
          <div class="bg-neutral-50 p-6">
            <PartnerConnectForm
              client:visible
              partnerId={partner.id}
              partnerName={partner.name}
              partnerNmls={partner.nmls}
              partnerLegalEntity={partner.legalEntityName}
            />
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- How TheGoodRoster works (§20) -->
  <div class="max-w-3xl mx-auto mb-12 px-4">
    <details class="bg-neutral-100 rounded-xl overflow-hidden" open>
      <summary class="p-6 cursor-pointer font-semibold text-primary-800 text-h3 select-none">How TheGoodRoster works</summary>
      <div class="px-6 pb-6 space-y-3 text-body-sm text-neutral-600">
        <p>
          TheGoodRoster is not a mortgage lender, broker, or loan originator. We publish local homebuyer guides, tools, and a small roster of licensed mortgage professionals.
        </p>
        <p>
          If you choose to contact a professional, your inquiry goes only to that person. The decision to move forward with them is entirely yours.
        </p>
        <p>
          Some listed professionals pay to participate. The choice of who you contact is yours alone, and the order professionals appear is randomized on every visit.
        </p>
        <p class="text-neutral-500">
          <a href="/privacy/">Privacy Policy</a> · <a href="/privacy/#do-not-sell">Your Privacy Choices</a> · <a href="/disclaimers/">Disclaimers</a>
        </p>
      </div>
    </details>
  </div>
</PageLayout>
