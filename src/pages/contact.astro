---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config/site';
---
<PageLayout
  title={`Contact | ${siteConfig.siteName}`}
  description={`Contact ${siteConfig.siteName} with general questions, content corrections, or partnership inquiries.`}
  breadcrumbs={[{ label: 'Contact', href: '/contact/' }]}
>
  <article class="py-8">
    <h1 class="text-h1 font-bold text-neutral-900 mb-4">Contact TheGoodRoster</h1>

    <div class="bg-accent-50 border border-accent-200 rounded-lg p-4 mb-8 text-body-sm">
      <p class="font-medium text-neutral-800">
        Looking for mortgage help? You're one click away &rarr; <a href="/community-partners/" class="text-primary-600 font-semibold">Community Partners</a>.
        This form is for content corrections, partnerships, press, and general feedback.
      </p>
    </div>

    <div class="max-w-xl">
      <p class="text-body text-neutral-600 mb-6">
        Use this form for general feedback, content corrections, partnership inquiries, or questions about {siteConfig.siteName}.
      </p>

      <form class="space-y-5" action={`mailto:${siteConfig.contactEmail}`} method="POST" enctype="text/plain">
        <div>
          <label for="contact-name" class="block text-body-sm font-medium text-neutral-700 mb-1">Name</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-body"
          />
        </div>

        <div>
          <label for="contact-email" class="block text-body-sm font-medium text-neutral-700 mb-1">Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-body"
          />
        </div>

        <div>
          <label for="contact-subject" class="block text-body-sm font-medium text-neutral-700 mb-1">Subject</label>
          <select
            id="contact-subject"
            name="subject"
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-body"
          >
            <option value="general">General question</option>
            <option value="correction">Content correction</option>
            <option value="partnership">Partnership inquiry</option>
            <option value="feedback">Feedback about the site</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="contact-message" class="block text-body-sm font-medium text-neutral-700 mb-1">Message</label>
          <textarea
            id="contact-message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-2.5 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-body"
          ></textarea>
        </div>

        <button type="submit" class="btn-primary">Send Message</button>
      </form>

      {(siteConfig.contactEmail && siteConfig.contactEmail !== '[CONTACT_EMAIL]') && (
        <p class="mt-6 text-body-sm text-neutral-500">
          You can also email us directly at <a href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>.
        </p>
      )}
    </div>
  </article>
</PageLayout>
