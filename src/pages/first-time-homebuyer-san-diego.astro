---
import BaseLayout from '../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../components/seo/BreadcrumbSchema.astro';
import ArticleSchema from '../components/seo/ArticleSchema.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import FAQAccordion from '../components/content/FAQAccordion.astro';
import ComparisonTable from '../components/content/ComparisonTable.astro';
import ScenarioBox from '../components/content/ScenarioBox.astro';
import PrimaryCTA from '../components/cta/PrimaryCTA.astro';
import PartnerListCTA from '../components/cta/PartnerListCTA.astro';
import EditorialBadge from '../components/trust/EditorialBadge.astro';
import TrustBlock from '../components/trust/TrustBlock.astro';
import UpdatedNotice from '../components/content/UpdatedNotice.astro';
import KeyStatBlock from '../components/content/KeyStatBlock.astro';
import { siteConfig } from '../config/site';

const title = `First-Time Home Buyer in San Diego: Complete 2026 Guide | ${siteConfig.siteName}`;
const description = 'Everything first-time home buyers need to know about purchasing a home in San Diego. Down payment assistance programs, loan options, income requirements, and step-by-step guidance for 2026.';
const datePublished = '2026-01-15';
const dateModified = '2026-04-15';
const canonicalUrl = `${siteConfig.siteUrl}/first-time-homebuyer-san-diego/`;

const breadcrumbs = [
  { label: 'First-Time Homebuyer San Diego', href: '/first-time-homebuyer-san-diego/' },
];

const faqItems = [
  {
    question: 'How much do first-time buyers need for a down payment in San Diego?',
    answer: 'It depends on the loan type. FHA loans require as little as 3.5% down, conventional loans start at 3%, and VA loans require zero down payment. On a $700,000 home, that ranges from $0 to $24,500. San Diego also has multiple down payment assistance programs that can cover part or all of your down payment.',
  },
  {
    question: 'What programs are available for first-time homebuyers in San Diego?',
    answer: 'San Diego has at least seven major assistance programs including the SDHC Low-Income and Middle-Income programs, San Diego County DCCA/CalHome, CalHFA MyHome, CalHFA Dream For All, GSFA Platinum, and the San Diego Black Homebuyers Program. These can provide between $10,000 and $150,000 in down payment and closing cost help.',
  },
  {
    question: 'What salary do you need to buy a home in San Diego?',
    answer: 'For a median-priced San Diego home near $1 million, you would generally need a household income of roughly $180,000 or more. However, many first-time buyers target homes in the $500,000 to $750,000 range, where a household income of $100,000 to $140,000 can be enough, especially with down payment assistance.',
  },
  {
    question: 'Is it a good time to buy a house in San Diego?',
    answer: 'Timing the market perfectly is nearly impossible. What matters more is whether buying makes sense for your personal financial situation. If you plan to stay in the home for at least five years, have stable income, manageable debt, and can afford the monthly payment without stretching your budget too thin, it could be a good time for you regardless of market conditions.',
  },
  {
    question: 'How long does the homebuying process take?',
    answer: 'From the day you start looking to closing day, most first-time buyers in San Diego spend 3 to 6 months. Getting pre-approved takes a few days to a week. House hunting varies widely. Once you are under contract, closing typically takes 30 to 45 days, though some DPA programs require additional processing time of 45 to 60 days.',
  },
  {
    question: 'What credit score do I need to buy a home in San Diego?',
    answer: 'FHA loans require a minimum credit score of 580 for the 3.5% down payment option, or 500 with 10% down. Conventional loans generally require 620 or higher. VA loans have no official minimum, but most lenders want at least 620. For the best interest rates, aim for 740 or above.',
  },
  {
    question: 'Can I buy a home in San Diego with no money down?',
    answer: 'Yes. VA loans offer zero down payment for eligible veterans, active-duty service members, and qualifying surviving spouses. Some down payment assistance programs can also effectively cover your entire down payment, making a no-money-down purchase possible even without military service.',
  },
  {
    question: 'What is the FHA loan limit in San Diego?',
    answer: 'The FHA loan limit for San Diego County is $1,077,550 for a single-family home as of 2025. This is one of the highest FHA limits in the country because San Diego is classified as a high-cost area. This limit is updated annually.',
  },
  {
    question: 'What is Mello-Roos and how does it affect my payment?',
    answer: 'Mello-Roos is a special tax district assessment common in newer San Diego communities. It funds infrastructure like roads, schools, and parks. It can add $200 to $500 or more per month to your property tax bill. Not all homes have Mello-Roos, so always ask before making an offer.',
  },
  {
    question: 'Do I need to pay back down payment assistance?',
    answer: 'It depends on the program. Some DPA programs offer forgivable loans that are waived after you live in the home for a certain number of years. Others are deferred loans with no monthly payments that come due when you sell, refinance, or no longer occupy the home. A few programs provide outright grants that never need to be repaid. Each program has different terms.',
  },
