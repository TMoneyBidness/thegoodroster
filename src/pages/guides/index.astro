---
import PageLayout from '../../layouts/PageLayout.astro';
import { siteConfig } from '../../config/site';
---
<PageLayout
  title={`San Diego Homebuyer Guides | ${siteConfig.siteName}`}
  description="Free guides for San Diego first-time homebuyers. Learn about loan programs, down payment assistance, closing costs, and more."
  breadcrumbs={[{ label: 'Guides', href: '/guides/' }]}
  wide={true}
>
  <div class="py-8">
    <h1 class="text-h1 font-bold text-neutral-900 mb-3">The San Diego First-Time Buyer Library</h1>
    <p class="text-body-lg text-neutral-600 mb-8 max-w-2xl">
      Plain-English guides to DPA, loan programs, Mello-Roos, closing costs, and the path to closing. Written for San Diego, updated regularly.
    </p>

    <!-- Featured guides -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      <a href="/first-time-homebuyer-san-diego/" class="card group block no-underline">
        <span class="inline-block px-2 py-0.5 bg-primary-50 text-primary-700 text-xs font-medium rounded-full mb-2">Featured</span>
        <h2 class="font-semibold text-neutral-900 group-hover:text-primary-700 mb-2">First-Time Home Buyer in San Diego: Complete Guide</h2>
        <p class="text-body-sm text-neutral-500">Everything you need to know about buying your first home in San Diego — from income requirements to DPA programs.</p>
      </a>

      <a href="/down-payment-assistance-san-diego/" class="card group block no-underline">
        <span class="inline-block px-2 py-0.5 bg-accent-50 text-accent-700 text-xs font-medium rounded-full mb-2">Popular</span>
        <h2 class="font-semibold text-neutral-900 group-hover:text-primary-700 mb-2">Down Payment Assistance Programs in San Diego</h2>
        <p class="text-body-sm text-neutral-500">$10,000 to $150,000 in help may be available. Complete breakdown of every DPA program in San Diego County.</p>
      </a>

      <a href="/loan-programs/" class="card group block no-underline">
        <h2 class="font-semibold text-neutral-900 group-hover:text-primary-700 mb-2">Loan Programs Compared</h2>
        <p class="text-body-sm text-neutral-500">FHA, VA, Conventional, CalHFA — compare all available loan types for San Diego buyers.</p>
      </a>
    </div>

    <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-8 text-center">
      <h2 class="text-h3 font-semibold text-neutral-800 mb-3">More Guides Coming Soon</h2>
      <p class="text-body text-neutral-600">
        We're building out our guide library with topics like closing costs, Mello-Roos, credit preparation, and neighborhood breakdowns.
        Check back regularly for new content.
      </p>
    </div>
  </div>
</PageLayout>
