<ProgramLayout
  title="FHA Loans in San Diego: Requirements, Limits & How to Apply (2026)"
  description="Everything San Diego first-time homebuyers need to know about FHA loans — loan limits, down payment requirements, credit scores, and how to combine FHA with local down payment assistance."
  programName="FHA Loans"
  keyStat="FHA loan limit in San Diego: $1,077,550 for 2026"
  datePublished="2026-04-15"
