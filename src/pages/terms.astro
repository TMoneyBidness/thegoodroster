---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config/site';
---
<PageLayout
  title={`Terms of Use | ${siteConfig.siteName}`}
  description={`Terms of use for ${siteConfig.siteName}, operated by ${siteConfig.companyName}.`}
  breadcrumbs={[{ label: 'Terms of Use', href: '/terms/' }]}
  noindex={true}
>
  <article class="py-8 prose">
    <h1>Terms of Use</h1>

    <p>
      {siteConfig.siteName} is an educational website operated by {siteConfig.companyName}.
      This site is not a lender, broker, or financial advisor. All information is provided
      for educational purposes only and should not be considered financial advice.
    </p>
    <p>
      For details about how we handle your data, see our <a href="/privacy/">Privacy Policy</a>.
      For information about our relationship with listed mortgage professionals, see our <a href="/disclaimers/">Disclaimers</a> page.
    </p>
    <p>
      If you have questions, please <a href="/contact/">contact us</a>.
    </p>
  </article>
</PageLayout>
