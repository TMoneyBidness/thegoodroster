---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config/site';
import ToolCTA from '../components/cta/ToolCTA.astro';
---
<PageLayout
  title={`Thank You | ${siteConfig.siteName}`}
  description="Thank you for your submission. Here's what happens next."
  noindex={true}
>
  <div class="py-12 max-w-2xl mx-auto text-center">
    <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-green-50 flex items-center justify-center text-green-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h1 class="text-h1 font-bold text-neutral-900 mb-4">Done. Here's what happens next.</h1>
    <p class="text-body-lg text-neutral-600 mb-8">
      Your inquiry has been sent to the professional you selected — and only to them.
    </p>

    <!-- What happens next -->
    <div class="text-left bg-neutral-50 rounded-xl p-8 mb-8">
      <h2 class="text-h3 font-semibold text-neutral-800 mb-4">What happens next</h2>
      <ol class="space-y-4">
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-bold text-body-sm">1</span>
          <div>
            <p class="font-medium text-neutral-800">Your info is delivered</p>
            <p class="text-body-sm text-neutral-500">Your details have been securely sent to the one professional you chose. No one else receives your information.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-bold text-body-sm">2</span>
          <div>
            <p class="font-medium text-neutral-800">A professional reaches out</p>
            <p class="text-body-sm text-neutral-500">Expect to hear from them within 1 business day, usually much sooner.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-bold text-body-sm">3</span>
          <div>
            <p class="font-medium text-neutral-800">You explore your options</p>
            <p class="text-body-sm text-neutral-500">The professional will discuss your situation, answer questions, and help you understand your options. No obligation.</p>
          </div>
        </li>
      </ol>
    </div>

    <!-- Co-buyer forward prompt -->
    <div class="bg-accent-50 border border-accent-200 rounded-xl p-6 mb-8 text-left">
      <h2 class="text-h3 font-semibold text-primary-800 mb-2">One thing to do in the next 5 minutes</h2>
      <p class="text-body-sm text-neutral-600 mb-3">
        If you're buying with a partner or co-buyer, forward them the link to your <a href="/tools/dpa-finder/" class="text-accent-600 font-medium">DPA Match results</a>. They'll see the same programs and can ask the professional their own questions on the intro call.
      </p>
    </div>

    <!-- While you wait -->
    <h2 class="text-h3 font-semibold text-neutral-800 mb-4">While you wait</h2>
    <div class="grid md:grid-cols-2 gap-4 text-left">
      <ToolCTA
        title="Your DPA Match"
        description="Re-run the quiz or share it with your co-buyer"
        href="/tools/dpa-finder/"
      />
      <ToolCTA
        title="Down Payment Assistance Guide"
        description="Deep dive into each DPA program's eligibility and details"
        href="/down-payment-assistance-san-diego/"
      />
    </div>
  </div>
</PageLayout>
