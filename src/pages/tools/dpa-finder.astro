---
/**
 * DPA Finder Tool Page
 * Note: The interactive DPA Finder component is Phase 2.
 * For now, this page links to the DPA Hub which has the full comparison table.
 */
import ToolLayout from '../../layouts/ToolLayout.astro';
import { siteConfig } from '../../config/site';
import PrimaryCTA from '../../components/cta/PrimaryCTA.astro';
---
<ToolLayout
  title={`Find Your Down Payment Assistance Match | ${siteConfig.siteName}`}
  description="Match with San Diego down payment assistance programs you may qualify for. SDHC, CalHFA, Dream For All, and more."
  toolName="DPA Finder"
>
  <Fragment slot="tool">
    <h1 class="text-h1 font-bold text-neutral-900 mb-3">Find Your Down Payment Assistance Match</h1>
    <p class="text-body-lg text-neutral-600 mb-6">
      San Diego has over 7 down payment assistance programs offering $10,000 to $150,000 in help. See which ones you may qualify for.
    </p>

    <!-- Phase 2: Interactive DPA Finder will go here -->
    <div class="bg-primary-50 border border-primary-200 rounded-xl p-8 text-center">
      <p class="text-body text-neutral-700 mb-4">
        Our interactive DPA Finder tool is coming soon. In the meantime, browse all available programs on our comprehensive guide page.
      </p>
      <PrimaryCTA text="Browse All DPA Programs" href="/down-payment-assistance-san-diego/" />
    </div>
  </Fragment>

  <h2>About down payment assistance in San Diego</h2>
  <p>
    Down payment is the #1 barrier for first-time homebuyers in San Diego. But many buyers don't know that between city, county, and state programs, significant assistance is available. Visit our <a href="/down-payment-assistance-san-diego/">complete DPA guide</a> for details on every program.
  </p>
</ToolLayout>
