---
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../config/site';
---
<PageLayout
  title={`Free Homebuyer Workshops | ${siteConfig.siteName}`}
  description="Free first-time homebuyer workshops in San Diego, hosted by ${siteConfig.companyName}. Learn about loan programs, DPA, and the buying process."
  breadcrumbs={[{ label: 'Workshops', href: '/workshops/' }]}
>
  <div class="py-8 max-w-2xl">
    <h1 class="text-h1 font-bold text-neutral-900 mb-4">Free San Diego First-Time Homebuyer Workshops</h1>
    <p class="text-body-lg text-neutral-600 mb-8">
      Live workshops for San Diego first-time buyers covering DPA programs, loan options, and the step-by-step buying process.
    </p>

    <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-8 text-center mb-8">
      <h2 class="text-h3 font-semibold text-neutral-800 mb-3">Next Round Coming Soon</h2>
      <p class="text-body text-neutral-600 mb-4">
        We host one workshop per quarter, capped at 50 seats. Check back for the next round, or explore our free tools now.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mt-4">
        <a href="/tools/dpa-finder/" class="btn-primary no-underline">Find My DPA Match</a>
        <a href="/first-time-homebuyer-san-diego/" class="btn-secondary no-underline">Read the Buyer Guide</a>
      </div>
    </div>
  </div>
</PageLayout>
